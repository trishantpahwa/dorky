{
    "all": true,
    "include": [
        "bin/**/*.js"
    ],
    "exclude": [
        "coverage/**",
        "tests/**",
        "test-for-later/**",
        "web-app/**",
        "node_modules/**",
        "**/*.config.js",
        "**/*.test.js"
    ],
    "reporter": [
        "text",
        "text-summary",
        "html",
        "lcov",
        "json"
    ],
    "check-coverage": false,
    "lines": 80,
    "functions": 80,
    "branches": 80,
    "statements": 80,
    "temp-directory": ".nyc_output",
    "report-dir": "coverage"
}